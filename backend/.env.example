# ── Supabase ──────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── OpenRouter AI (2 keys + 2 models for rotation) ───────
OPENROUTER_API_KEY_1=sk-or-v1-xxxxxxxxxxxx
OPENROUTER_API_KEY_2=sk-or-v1-yyyyyyyyyyyy
OPENROUTER_MODEL_1=google/gemini-2.0-flash-001
OPENROUTER_MODEL_2=anthropic/claude-3.5-sonnet

# ── Twilio WhatsApp (fill when friend's bot is ready) ─────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Server ────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
